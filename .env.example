# OpenAI API Key (Required)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API Key (Required for web research)
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# LLM Provider Configuration
# Choose between 'openai' or 'anthropic'
LLM_PROVIDER=anthropic

# Optional: Model Configuration
# OPENAI_MODEL=gpt-4
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ANTHROPIC_MODEL=anthropic.claude-opus-4-6-v1
# ANTHROPIC_BASE_URL=floodgate base url

# Optional: ChromaDB Configuration
# CHROMA_PERSIST_DIRECTORY=./chroma_db

# WordPress Publishing Configuration (Optional)
# Required only if you want to publish blogs to WordPress
WORDPRESS_SITE_URL=https://yourblog.com
WORDPRESS_USERNAME=your_username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional: WordPress Publishing Defaults
WORDPRESS_DEFAULT_STATUS=draft
WORDPRESS_DEFAULT_AUTHOR_ID=1
WORDPRESS_API_TIMEOUT=30